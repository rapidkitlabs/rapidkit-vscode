{
  "name": "rapidkit-vscode",
  "displayName": "Workspai (by RapidKit)",
  "description": "The AI workspace for backend teams. Build backend systems with AI that knows your workspace, generate projects and modules from intent, debug with full context, and ship faster — all inside VS Code. FastAPI, NestJS, Spring Boot, Go/Fiber & Go/Gin.",
  "version": "0.24.1",
  "publisher": "rapidkit",
  "icon": "media/icons/icon.png",
  "galleryBanner": {
    "color": "#0F172A",
    "theme": "dark"
  },
  "preview": false,
  "qna": "https://github.com/getrapidkit/rapidkit-vscode/discussions",
  "engines": {
    "vscode": "^1.100.0"
  },
  "extensionDependencies": [],
  "capabilities": {
    "languageModels": "enabled"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Snippets",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "workspai",
    "rapidkit",
    "AI",
    "chatgpt",
    "fastapi",
    "nestjs",
    "spring",
    "springboot",
    "java",
    "go",
    "backend",
    "scaffold",
    "workspace",
    "python",
    "typescript",
    "rest api",
    "code generation",
    "boilerplate",
    "monorepo"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/getrapidkit/rapidkit-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/getrapidkit/rapidkit-vscode/issues"
  },
  "homepage": "https://www.workspai.com/",
  "license": "MIT",
