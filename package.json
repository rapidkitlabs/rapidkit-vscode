    "configuration": {
      "title": "Workspai",
      "properties": {
        "workspai.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Path to Python executable",
          "scope": "window"
        },
        "workspai.defaultKit": {
          "type": "string",
          "default": "fastapi.standard",
          "enum": [
            "fastapi.standard",
            "fastapi.ddd",
            "nestjs.standard",
            "gofiber.standard",
            "gogin.standard",
            "springboot.standard"
          ],
          "enumDescriptions": [
            "FastAPI with standard features",
            "NestJS with standard features",
            "Go/Fiber with standard features",
            "Go/Gin with standard features",
            "Spring Boot with standard features"
          ],
          "description": "Default kit for new projects"
        },
        "workspai.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh project tree when files change"
        },
        "workspai.showWelcomeOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Show welcome page when extension activates"
        },
        "workspai.showOnboardingTips": {
          "type": "boolean",
          "default": true,
          "description": "Show in-product onboarding tips for new Workspai AI and telemetry features"
        },
        "workspai.templatePreview": {
          "type": "boolean",
          "default": true,
          "description": "Show template preview before generation"
        },
        "workspai.notifications": {
          "type": "string",
          "default": "all",
          "enum": [
            "all",
            "errors",
            "none"
          ],
          "description": "Control notification verbosity"
        },
        "workspai.terminal.autoActivate": {
          "type": "boolean",
          "default": true,
          "description": "Automatically activate Python environment in integrated terminal"
        },
        "workspai.git.autoInit": {
          "type": "boolean",
          "default": true,
          "description": "Initialize git repository for new projects"
        },
        "workspai.dontShowFirstTimeSetup": {
          "type": "boolean",
          "default": false,
          "description": "Don't show first-time setup welcome message"
        },
        "workspai.checkForUpdates": {
          "type": "boolean",
          "default": true,
          "description": "Check for RapidKit npm package updates"
        },
        "workspai.networkTimeoutMs": {
          "type": "number",
          "default": 10000,
          "minimum": 1000,
          "maximum": 60000,
          "description": "Network timeout in milliseconds for examples and kits fetching"
        },
        "workspai.commandTimeoutMs": {
          "type": "number",
          "default": 8000,
          "minimum": 1000,
          "maximum": 60000,
          "description": "Timeout in milliseconds for local CLI and git commands used by the extension (AI scanning, module discovery, and diagnostics)"
        },
        "workspai.preferredModel": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "claude-opus-4-6",
            "claude-opus-4-5",
            "claude-sonnet-4-6",
            "claude-sonnet-4-5",
            "claude-sonnet-4",
            "claude-haiku-4-5",
            "gpt-5.4",
            "gpt-5.4-mini",
            "gpt-5.3-codex",
            "gpt-5.2-codex",
            "gpt-5.2",
            "gpt-5-mini",
            "gpt-4.1",
            "gpt-4o",
            "gemini-3.1-pro",
            "gemini-3-flash",
            "gemini-2.5-pro",
            "grok-code-fast-1",
            "raptor-mini"
          ],
          "enumDescriptions": [
            "Automatically select the best available Copilot model",
            "Claude Opus 4.6 — strongest reasoning, 192K context (3x cost)",
            "Claude Opus 4.5 — deep reasoning, 160K context (3x cost)",
            "Claude Sonnet 4.6 — fast and highly capable, 160K context",
            "Claude Sonnet 4.5 — balanced quality and speed, 160K context",
            "Claude Sonnet 4 — solid all-rounder, 144K context",
            "Claude Haiku 4.5 — ultra-fast, 160K context (0.33x cost)",
            "GPT-5.4 — latest OpenAI flagship, 400K context",
            "GPT-5.4 Mini — fast GPT-5.4, 400K context (0.33x cost)",
            "GPT-5.3 Codex — code-optimised, 400K context",
            "GPT-5.2 Codex — code-optimised, 400K context",
            "GPT-5.2 — strong general model, 192K context",
            "GPT-5 Mini — fast and free, 192K context",
            "GPT-4.1 — reliable, 128K context (free)",
            "GPT-4o — proven quality, 68K context (free)",
            "Gemini 3.1 Pro — Google flagship, 173K context",
            "Gemini 3 Flash — ultra-fast Google model, 173K context (0.33x cost)",
            "Gemini 2.5 Pro — strong reasoning, 173K context",
            "Grok Code Fast 1 — xAI code model (0.25x cost)",
            "Raptor Mini — experimental (free)"
          ],
          "description": "Preferred AI model for Workspai AI features. Requires GitHub Copilot.",
          "scope": "window"
        }
      }
    },
    "keybindings": [
      {
        "command": "workspai.createWorkspace",
        "key": "ctrl+shift+r ctrl+shift+w",
        "mac": "cmd+shift+r cmd+shift+w"
      },
      {
        "command": "workspai.createProject",
        "key": "ctrl+shift+r ctrl+shift+p",
        "mac": "cmd+shift+r cmd+shift+p"
      },
      {
        "command": "workspai.addModule",
        "key": "ctrl+shift+r ctrl+shift+m",
        "mac": "cmd+shift+r cmd+shift+m"
      },
      {
        "command": "workspai.debugWithAI",
        "key": "ctrl+shift+r ctrl+shift+d",
        "mac": "cmd+shift+r cmd+shift+d"
      },
      {
        "command": "workspai.workspaceBrain",
        "key": "ctrl+shift+r ctrl+shift+b",
        "mac": "cmd+shift+r cmd+shift+b"
      }
    ],
    "snippets": [
      {
        "language": "python",
        "path": "./snippets/python.json"
      },
      {
        "language": "typescript",
        "path": "./snippets/typescript.json"
      },
      {
        "language": "yaml",
        "path": "./snippets/yaml.json"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": ".rapidkitrc.json",
        "url": "./schemas/rapidkitrc.schema.json"
      },
      {
        "fileMatch": "rapidkit.json",
        "url": "./schemas/rapidkit.schema.json"
      },
      {
        "fileMatch": "**/module.yaml",
        "url": "./schemas/module.schema.json"
      }
    ],
    "yamlValidation": [
      {
        "fileMatch": "**/module.yaml",
        "url": "./schemas/module.schema.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "clean:dist": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean:dist && npm run esbuild-base -- --production && cd webview-ui && npm run build",
    "compile": "npm run clean:dist && tsc -p ./ && npm run webview:build",
    "watch": "tsc -watch -p ./",
    "esbuild-base": "node esbuild.js",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "webview:install": "cd webview-ui && npm install",
    "webview:build": "cd webview-ui && npm run build",
    "webview:watch": "cd webview-ui && npm run watch",
    "dev": "concurrently \"npm run esbuild-watch\" \"npm run webview:watch\"",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:stress:incident-studio": "vitest run src/test/incidentStudioLifecycle.test.ts src/test/incidentStudioStressGate.test.ts src/test/debounceWatchers.test.ts",
    "test:vscode": "vscode-test",
    "release:stop-gate": "node scripts/release-stop-gate.mjs",
    "release:stop-gate:wave2": "node scripts/release-stop-gate.mjs --manifest releases/wave2-foundation-gate.json --marker releases/fixtures/wave2-kpi-marker.json",
    "release:stop-gate:wave3": "node scripts/release-stop-gate.mjs --manifest releases/wave3-foundation-gate.json --claim-checklist releases/wave3-claim-checklist.md --enforce-claim-checklist --marker releases/fixtures/wave3-kpi-marker.json",
    "sync:modules": "node scripts/sync-modules.mjs",
    "package": "vsce package",
    "publish": "vsce publish",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run lint && npm run format:check && npm test",
    "prepare": "husky"
  },
