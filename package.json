        "view": "rapidkitWorkspaces",
        "contents": "No Workspai workspaces found.\n\nUse the Actions panel above to create your first workspace."
      },
      {
        "view": "rapidkitProjects",
        "contents": "No workspace selected.\n\nSelect a workspace from the Workspaces panel or use Actions to create projects.",
        "when": "!workspai.workspaceSelected"
      },
      {
        "view": "rapidkitProjects",
        "contents": "No projects found in this workspace.\n\nUse the Actions panel to create your first project.",
        "when": "workspai.workspaceSelected && workspai:noProjects"
      },
      {
        "view": "rapidkitModules",
        "contents": "$(package)\n\n**Select a Project**\n\nChoose a project from the Projects panel to browse and install available modules.\n\n[$(list-tree) Open Projects](command:rapidkitProjects.focus)",
        "when": "!workspai:projectSelected"
      },
      {
        "view": "rapidkitModules",
        "contents": "$(sync~spin) Loading available modules…",
        "when": "workspai:projectSelected"
      }
